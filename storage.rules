rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /productos/{allPaths=**} {
      allow read: if true;

      allow write: if request.auth != null
        && firestore.get(
          /databases/(default)/documents/usuarios/$(request.auth.uid)
        ).data.rol == "admin";
    }
  }
}
